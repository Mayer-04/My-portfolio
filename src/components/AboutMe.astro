---
interface Props {
  title: string;
}

const myInformation = [
  {
    name: "Mayer Andres Chaves.",
    age: "Tengo 23 años.",
    address: "De Bogotá, Colombia.",
    learning: "Aprendiendo actualmente",
  },
];

const { title } = Astro.props;
---

<article class="col-span-4 border p-7">
  <h3 class="text-2xl font-semibold mb-2 underline text-blue-300/95">
    {title}
  </h3>
  <ul class="list-disc">
    {
      myInformation.map(({ name, age, address, learning }) => (
        <>
          <li>{name}</li>
          <li>{age}</li>
          <li>{address}</li>
          <li>
            {learning} <strong class="text-blue-300/95">Go.</strong>
          </li>
        </>
      ))
    }
  </ul>
</article>

<style>
  article {
    background: linear-gradient(
      30.6deg,
      rgba(124, 130, 177, 0.12) 28.69%,
      hsla(241, 41%, 62%, 0.3) 100%
    );
    border: 1px solid hsla(241, 41%, 62%, 0.3);
    border-radius: 12px;
  }
</style>
