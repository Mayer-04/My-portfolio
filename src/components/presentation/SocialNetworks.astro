---
interface Props {
  href: string;
  text: string;
}

const { href, text } = Astro.props;
---

<a
  class="flex justify-center items-center gap-3 py-2 px-5 rounded-full hover:text-blue-300/95 transition-colors bg-gradient-100"
  href={href}
  target="_blank"
  rel="noopener noreferrer"
>
  <slot name="icon" />
  {text}
</a>
