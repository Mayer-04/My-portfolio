---
interface Props {
  title: string;
  year: string;
  company: string;
  description: string;
}

const { title, description, year, company } = Astro.props;
---

<article
  class="col-span-5 p-7 bg-primary-gradient border border-mayer-100 rounded-xl"
>
  <h3 class="text-2xl font-semibold mb-2 text-blue-300/95 underline">
    {title}
  </h3>
  <ol class="relative border-s border-blue-300/95">
    <li class="mb-10 ms-4">
      <div
        class="absolute size-3 rounded-full mt-1.5 -start-1.5 border border-white bg-blue-300/95"
      >
      </div>
      <time class="mb-1 text-sm font-normal leading-none">{year}</time>
      <h3 class="text-lg font-semibold mt-1 text-blue-300/95">
        {company}
      </h3>
      <p class="mb-4 text-base font-normal">
        {description}
      </p>
    </li>
  </ol>
</article>
