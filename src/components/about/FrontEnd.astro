---
import { Icon } from "astro-icon/components";
import BentoItem from "@/components/about/BentoItem.astro";

interface Props {
  class?: string;
}
---

<article
  class=`${Astro.props.class} p-5 bg-gradient-100 border border-mayer-100 rounded-xl`
>
  <div class="grid grid-cols-3 gap-y-3">
    <BentoItem>
      <Icon name="front-end/html" slot="icon" class="size-8" />
      <h3 slot="technology">HTML</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/css" slot="icon" class="size-8" />
      <h3 slot="technology">CSS</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/tailwindcss" slot="icon" class="size-8" />
      <h3 slot="technology">TailwindCSS</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/javascript" slot="icon" class="size-8" />
      <h3 slot="technology">JavaScript</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/typescript" slot="icon" class="size-8" />
      <h3 slot="technology">TypeScript</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/astro" slot="icon" class="size-8" />
      <h3 slot="technology">Astro</h3>
    </BentoItem>

    <BentoItem>
      <Icon name="front-end/angular" slot="icon" class="size-8" />
      <h3 slot="technology">Angular</h3>
    </BentoItem>
  </div>
</article>
