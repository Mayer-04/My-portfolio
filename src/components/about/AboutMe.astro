---
interface Props {
  title: string;
  class?: string;
}

const { title } = Astro.props;
---

<article
  class=`${Astro.props.class} p-7 bg-gradient-100 border border-mayer-100 rounded-xl`
>
  <h3 class="text-2xl font-semibold mb-2 underline text-blue-300/95">
    {title}
  </h3>
  <!-- TODO: Por mejorar -->
  <p class="text-pretty">
    Mayer Andres Chaves, Tengo 23 años, De Bogotá, Colombia, estoy aprendiendo
    Python
  </p>
</article>
