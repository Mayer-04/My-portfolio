---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<article
  class="col-span-4 p-5 bg-primary-gradient border border-mayer-100 rounded-xl"
>
  <h2 class="text-2xl font-semibold mb-5 text-emerald-300 text-center">
    {title}
  </h2>

  <div class="grid grid-cols-3 gap-5">
    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/docker" class="size-8" />

      <h3>Docker</h3>
    </div>

    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/node" class="size-8" />
      <h3>Node.js</h3>
    </div>

    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/express" class="size-8" />
      <h3>Express</h3>
    </div>

    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/mongodb" class="size-8" />
      <h3>MongoDB</h3>
    </div>

    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/postgresql" class="size-8" />
      <h3>PostgreSQL</h3>
    </div>

    <div class="flex flex-col justify-center items-center">
      <Icon name="back-end/prisma" class="size-8" />
      <h3>Prisma</h3>
    </div>
  </div>
</article>
