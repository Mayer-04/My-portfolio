---
import Logo from "@/components/Logo.astro";
import Code from "@/icons/Code.astro";

const navList = [
  { name: "Sobre mí", url: "/" },
  { name: "Experiencia", url: "#experience" },
  { name: "Tecnologías", url: "#technologies" },
  { name: "Proyectos", url: "#projects" },
  { name: "Contacto", url: "#contact" },
];
---

<header class="flex justify-center items-center w-full py-5 gap-14 h-28">
  <Logo>
    <h2 class="text-xl font-bold" slot="title">Mayer</h2>
    <Code class="size-8" slot="icon" />
  </Logo>

  <nav class="flex justify-center items-center">
    {
      navList.map(({ name, url }) => (
        <a
          class="hover:bg-primary rounded-full py-1 px-3 transition-colors"
          href={url}
        >
          {name}
        </a>
      ))
    }
  </nav>
</header>
