---
import { navLinks } from "@/data/nav-links";
import { Icon } from "astro-icon/components";
import Logo from "@/components/header/Logo.astro";
---

<header
  id="home"
  class="flex justify-center items-center w-full py-6 gap-14 sticky top-0 left-0 z-10"
>
  <Logo>
    <h2 class="text-xl font-semibold" slot="title">Mayer</h2>
    <Icon name="code" slot="icon" class="size-8" />
  </Logo>

  <nav class="flex justify-center items-center">
    {
      navLinks.map(({ name, url }) => (
        <a
          class="inline-block rounded-full py-1 px-3 hover:bg-mayer-100 transition"
          href={url}
        >
          {name}
        </a>
      ))
    }
  </nav>
</header>

<style>
  #home {
    animation: backdrop-blur linear both;
    animation-timeline: scroll();
    animation-range: 0 500px;
  }

  @keyframes backdrop-blur {
    to {
      background: rgb(23, 23, 23, 0.5);
      backdrop-filter: blur(15px);
    }
  }
</style>
